#!/usr/bin/env php
<?php

class ForkDiffChecker
{
    private string $baseOwner;
    private string $baseRepo;
    private string $baseBranch;
    private ?string $token;

    public function __construct(string $repoUrl, ?string $token = '')
    {
        $this->token = $token;

        if (! preg_match('#github\.com/([^/]+)/([^/.]+)#', $repoUrl, $matches)) {
            throw new InvalidArgumentException('Invalid GitHub repo URL');
        }

        $this->baseOwner = $matches[1];
        $this->baseRepo  = $matches[2];

        $info = $this->getRepoInfo($this->baseOwner, $this->baseRepo);
        if (! $info) {
            throw new RuntimeException('Could not fetch base repo info');
        }

        $this->baseBranch = $info['default_branch'];
    }

    public function run(): void
    {
        $repoFullName = $this->baseOwner . '/' . $this->baseRepo;
        $repoUrl      = 'https://github.com/' . $repoFullName;
        echo "===".PHP_EOL;
        echo 'Base repo: ' . $repoFullName . ' (branch: ' . $this->baseBranch . ')' . PHP_EOL;
        echo 'Repo URL: ' . $repoUrl . PHP_EOL;

        $packageName = $this->getComposerPackageNameForRepo(
            $this->baseOwner,
            $this->baseRepo,
            $this->baseBranch
        );
        if ($packageName) {
            echo 'Package name: ' . $packageName . PHP_EOL;
        }
        echo "===".PHP_EOL;
        echo PHP_EOL;

        $this->spin('Fetching forks...');
        $forks   = $this->getForks($this->baseOwner, $this->baseRepo);
        $total   = count($forks);
        $results = [];

        foreach ($forks as $i => $fork) {
            $forkOwner = $fork['owner']['login'];

            $this->spin(sprintf('Fetching branches for fork %d/%d: %s', $i + 1, $total, $forkOwner));
            $branches = $this->getBranches($forkOwner, $this->baseRepo);

            foreach ($branches as $branch) {
                $this->spin(sprintf(
                    'Checking fork %d/%d: %s @ %s',
                    $i + 1,
                    $total,
                    $forkOwner,
                    $branch
                ));

                $result = $this->compareFork($forkOwner, $branch);
                if ($result) {
                    $results[] = $result;
                }
            }
        }

        $this->clearSpinner();

        usort($results, fn (array $a, array $b): int => $b['aheadBy'] <=> $a['aheadBy']);

        foreach ($results as $res) {
            echo 'Fork: ' . $res['forkOwner'] . ' @ ' . $res['forkBranch'] . PHP_EOL;
            echo '  Repo: ' . $res['forkRepoUrl'] . PHP_EOL;
            echo '  Package: ' . ($res['packageName'] ?? 'unknown') . PHP_EOL;
            echo '  Ahead by: ' . $res['aheadBy'] . ' commits' . PHP_EOL;
            echo '  Behind by: ' . $res['behindBy'] . ' commits' . PHP_EOL;
            echo '  Last commit: ' . $res['lastCommit'] . PHP_EOL;
            echo '  Compare: ' . $res['diffUrl'] . PHP_EOL . PHP_EOL;
        }

        if (empty($results)) {
            echo 'No forks are ahead of base repo.' . PHP_EOL;
        }

        $this->printSummary($results);
    }
    private function getRepoInfo(string $owner, string $repo): ?array
    {
        return $this->fetchJson('https://api.github.com/repos/' . $owner . '/' . $repo);
    }
    private function getForks(string $owner, string $repo): array
    {
        $allForks = [];
        $page     = 1;

        while (true) {
            $batch = $this->fetchJson(
                'https://api.github.com/repos/' . $owner . '/' . $repo
                . '/forks?per_page=100&page=' . $page
            );

            if (empty($batch)) {
                break;
            }

            $allForks = array_merge($allForks, $batch);

            if (count($batch) < 100) {
                break;
            }

            $page++;
        }

        return $allForks;
    }
    private function compareFork(string $forkOwner, string $forkBranch): ?array
    {
        $apiUrl     = 'https://api.github.com/repos/'
            . $this->baseOwner . '/' . $this->baseRepo
            . '/compare/' . $this->baseBranch . '...'
            . $forkOwner . ':' . $forkBranch;
        $compareUrl = 'https://github.com/'
            . $this->baseOwner . '/' . $this->baseRepo
            . '/compare/' . $this->baseBranch . '...'
            . $forkOwner . ':' . $forkBranch;

        $data = $this->fetchJson($apiUrl);

        if (!$data || ($data['ahead_by'] ?? 0) <= 0) {
            return null;
        }

        $commits     = $data['commits'] ?? [];
        $lastRawDate = $commits ? end($commits)['commit']['committer']['date'] : null;
        $lastCommit  = 'unknown';
        $daysAgo = 0;
        if ($lastRawDate) {
            $dateTime   = new DateTime($lastRawDate);
            $now        = new DateTime('now');
            $interval   = $dateTime->diff($now);
            $daysAgo    = $interval->days;
            $lastCommit = $daysAgo . ' day' . ($daysAgo === 1 ? '' : 's') . ' ago';
        }

        $forkRepoUrl = 'https://github.com/' . $forkOwner . '/' . $this->baseRepo;
        $packageName = $this->getComposerPackageNameForRepo(
            $forkOwner,
            $this->baseRepo,
            $forkBranch
        );

        return [
            'forkOwner'   => $forkOwner,
            'forkBranch'  => $forkBranch,
            'forkRepoUrl' => $forkRepoUrl,
            'packageName' => $packageName,
            'aheadBy'     => $data['ahead_by'],
            'behindBy'    => $data['behind_by'],
            'lastCommit'  => $lastCommit,
            'daysAgo'     => $daysAgo,
            'diffUrl'     => $compareUrl,
        ];
    }
    private array $packageNameCache = [];
    private function getComposerPackageNameForRepo(
        string $owner,
        string $repo,
        string $branch
    ): ?string {
        $cacheKey = $owner . '/' . $repo;
        if (array_key_exists($cacheKey, $this->packageNameCache)) {
            return $this->packageNameCache[$cacheKey];
        }

        $rawUrl = sprintf(
            'https://raw.githubusercontent.com/%s/%s/%s/composer.json',
            $owner,
            $repo,
            $branch
        );

        $contextOptions = [
            'http' => [
                'user_agent' => 'ForkDiffChecker',
            ],
        ];
        if ($this->token) {
            $contextOptions['http']['header'] = 'Authorization: token ' . $this->token . "\r\n";
        }
        $context = stream_context_create($contextOptions);
        $json    = @file_get_contents($rawUrl, false, $context);
        if (! $json) {
            $this->packageNameCache[$cacheKey] = null;
            return null;
        }

        $data = json_decode($json, true);
        $this->packageNameCache[$cacheKey] = $data['name'] ?? null;
        return $this->packageNameCache[$cacheKey];
    }
    private function fetchJson(string $url): ?array
    {
        $options = [
            'http' => [
                'user_agent'    => 'ForkDiffChecker',
                'ignore_errors' => true,
            ],
        ];
        if ($this->token) {
            $options['http']['header'] = 'Authorization: token ' . $this->token . "\r\n";
        }

        $context = stream_context_create($options);
        $json    = @file_get_contents($url, false, $context);

        $statusLine = $http_response_header[0] ?? '';
        preg_match('#HTTP/\S+ (\d+)#', $statusLine, $m);
        $statusCode = (int) ($m[1] ?? 200);

        if ($statusCode === 403 || $statusCode === 429) {
            $resetAt = null;
            foreach ($http_response_header as $header) {
                if (stripos($header, 'X-RateLimit-Reset:') === 0) {
                    $resetAt = (int) trim(explode(':', $header, 2)[1]);
                    break;
                }
            }

            $waitSeconds = $resetAt ? max(1, $resetAt - time()) : 60;
            $this->clearSpinner();
            echo PHP_EOL . 'Rate limited by GitHub. Waiting ' . $waitSeconds . 's for reset...' . PHP_EOL;
            sleep($waitSeconds);

            $json = @file_get_contents($url, false, $context);
            $statusLine = $http_response_header[0] ?? '';
            preg_match('#HTTP/\S+ (\d+)#', $statusLine, $m);
            $statusCode = (int) ($m[1] ?? 200);
        }

        // Return null for any non-2xx response
        if ($statusCode < 200 || $statusCode >= 300) {
            return null;
        }

        return $json ? json_decode($json, true) : null;
    }

    public static function resolveRepoUrlFromPackage(
        string $packageName,
        ?string $token = ''
    ): string {
        $url     = 'https://packagist.org/packages/' . $packageName . '.json';
        $options = [
            'http' => [
                'user_agent' => 'ForkDiffChecker',
            ],
        ];
        if ($token) {
            $options['http']['header'] = 'Authorization: token ' . $token . "\r\n";
        }
        $context = stream_context_create($options);
        $json    = @file_get_contents($url, false, $context);
        if (! $json) {
            throw new RuntimeException('Could not fetch Packagist info for ' . $packageName);
        }

        $data = json_decode($json, true);
        $repo = $data['package']['repository'] ?? null;
        if (! $repo || ! preg_match('#github\.com/[^/]+/[^/.]+#', $repo)) {
            throw new RuntimeException('Invalid or unsupported repository URL for ' . $packageName);
        }

        if (! preg_match('#^https?://#', $repo)) {
            $repo = str_replace('git@github.com:', 'https://github.com/', $repo);
            $repo = rtrim($repo, '.git');
        }

        return $repo;
    }

    private function getBranches(string $owner, string $repo): array
    {
        $allBranches = [];
        $page        = 1;

        while (true) {
            $batch = $this->fetchJson(
                'https://api.github.com/repos/' . $owner . '/' . $repo
                . '/branches?per_page=100&page=' . $page
            );

            if (empty($batch)) {
                break;
            }

            foreach ($batch as $branch) {
                $allBranches[] = $branch['name'];
            }

            if (count($batch) < 100) {
                break;
            }

            $page++;
        }

        return $allBranches;
    }


    private array $spinnerFrames = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
    private int $spinnerIndex = 0;

    private function spin(string $message): void
    {
        $frame = $this->spinnerFrames[$this->spinnerIndex % count($this->spinnerFrames)];
        $this->spinnerIndex++;
        $padded = str_pad($frame . ' ' . $message, 80);
        echo "\r" . $padded;
    }

    private function clearSpinner(): void
    {
        echo "\r" . str_repeat(' ', 80) . "\r";
    }

    private function printSummary(array $results): void
    {
        if (empty($results)) {
            return;
        }

        $top = fn (array $arr, int $n) => array_slice($arr, 0, min($n, count($arr)));
        $label = fn (array $r) => $r['forkOwner'] . ' @ ' . $r['forkBranch'];

        echo '─────────────────────────────────────────────────────────' . PHP_EOL;
        echo 'SUMMARY' . PHP_EOL;
        echo '─────────────────────────────────────────────────────────' . PHP_EOL . PHP_EOL;

        // 1. Most ahead
        $mostAhead = $results; // already sorted by aheadBy desc
        echo 'Most ahead:' . PHP_EOL;
        foreach ($top($mostAhead, 3) as $i => $r) {
            echo '  ' . ($i + 1) . '. ' . $label($r) . ' (+' . $r['aheadBy'] . ' , -' . $r['behindBy'] . ' , ' . $r['lastCommit'] . ')' . PHP_EOL;
        }
        echo PHP_EOL;

        // 2. Least behind
        $leastBehind = $results;
        usort($leastBehind, fn ($a, $b) => $a['behindBy'] <=> $b['behindBy']);
        echo 'Least behind:' . PHP_EOL;
        foreach ($top($leastBehind, 3) as $i => $r) {
            echo '  ' . ($i + 1) . '. ' . $label($r) . ' (-' . $r['behindBy'] . ' , +' . $r['aheadBy'] . ' , ' . $r['lastCommit'] . ')' . PHP_EOL;
        }
        echo PHP_EOL;

        $best = $results;
        usort($best, fn ($a, $b) => ($a['aheadBy'] - $a['behindBy']) <=> ($b['aheadBy'] - $b['behindBy']));
        echo 'Best balance:' . PHP_EOL;
        foreach ($top($best, 3) as $i => $r) {
            echo '  ' . ($i + 1) . '. ' . $label($r) . ' (-' . $r['behindBy'] . ' , +' . $r['aheadBy'] . ' , ' . $r['lastCommit'] . ')' . PHP_EOL;
        }
        echo PHP_EOL;

        // 3. Most recently changed
        $recentlyChanged = $results;
        usort($recentlyChanged, fn ($a, $b) => $a['daysAgo'] <=> $b['daysAgo']);
        echo 'Most recently changed:' . PHP_EOL;
        foreach ($top($recentlyChanged, 3) as $i => $r) {
            echo '  ' . ($i + 1) . '. ' . $label($r) . ' (' . $r['lastCommit'] . ', +' . $r['aheadBy'] . ' , -' . $r['behindBy'] . ')' . PHP_EOL;
        }
        echo PHP_EOL;
    }

}

function printHelp(): void
{
    echo <<<'EOT'
Usage:
  sake-composer-fork-comparison <GitHubRepoURL|PackagistPackage> [token]

Examples:
  sake-composer-fork-comparison https://github.com/vendor/repo
  sake-composer-fork-comparison vendor/repo

EOT;
}

$input = $argv[1] ?? '';

if (in_array($input, ['--help', '-h', ''], true)) {
    printHelp();
    exit(0);
}

$token = $argv[2] ?? null;

if (! $token) {
    // 1. auth.json
    $authPath = getenv('HOME') . '/.config/composer/auth.json';
    if (is_file($authPath)) {
        $json = json_decode(file_get_contents($authPath), true);
        $token = $json['github-oauth']['github.com'] ?? '';
    }
}

if (! $token) {
    // 2. ENV
    $token = getenv('GITHUB_TOKEN') ?: '';
}

if (! $token) {
    // 3. .env up the tree
    $dir = __DIR__;
    while ($dir) {
        $envPath = $dir . '/.env';
        if (is_file($envPath)) {
            $lines = file($envPath, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
            foreach ($lines as $line) {
                if (strpos($line, 'GITHUB_TOKEN=') === 0) {
                    $token = str_replace('"', '', substr($line, 13));
                    break 2;
                }
            }
        }
        $parentDir = dirname($dir);
        if ($parentDir === $dir) {
            break;
        }
        $dir = $parentDir;
    }
}

try {
    if (preg_match('#^(https?://|git@)#', $input)) {
        $repoUrl = $input;
    } else {
        $repoUrl = ForkDiffChecker::resolveRepoUrlFromPackage($input, $token);
    }

    $checker = new ForkDiffChecker($repoUrl, $token);
    $checker->run();
} catch (Throwable $e) {
    echo 'Error: ' . $e->getMessage() . PHP_EOL;
    exit(1);
}
