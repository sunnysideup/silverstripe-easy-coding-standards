#!/usr/bin/env bash

############################################ BASICS
SCRIPT_DIR="${COMPOSER_RUNTIME_BIN_DIR:?COMPOSER_RUNTIME_BIN_DIR not set}"
WORKING_DIR=$(pwd)
source "$SCRIPT_DIR/sake-self-methods"
SCRIPT_SUMMARY="Displays a list of all available sake commands and their descriptions"

############################################ DIR
dir='./'

############################################ SETTINGS
more="no"
section=""
help='no'
while (($#)); do
    case $1 in
    -m | --more)
        more="yes"
        ;;
    *)
        if sake_handle_help_flag "$1"; then
            shift
            continue
        fi
        # Treat any other argument as a section name
        section="${1^^}"  # Convert to uppercase
        more="yes"  # Show detailed help for this section
        ;;
    esac
    shift
done


############################################ HELP

help_and_exit() {

    ECHOHEAD "self help"
    echonice "Displays a list of all available sake commands and their descriptions"
    echonice ""
    echonice "Directory of script:           $SCRIPT_DIR"
    echonice "Directory to analyse:          $WORKING_DIR/$dir"

    ECHOHEAD "Current settings:"
    echonice "More (-m|--more):              $more"
    echonice "Section:                       ${section:-all}"

    ECHOHEAD "Available settings:"
    echonice "-m, --more                     show detailed help for all sections"
    echonice "[section]                      show detailed help for specific section"

    ECHOHEAD "Example usage:"
    echonice "sake-help                      # Basic list of all commands"
    echonice "sake-help --more               # Detailed help for all sections"
    echonice "sake-help git                  # Detailed help for GIT section only"
    echonice "sake-help composer             # Detailed help for COMPOSER section only"

    echofunctions
    exit
}


sake_check_help_and_exit

############################################ CODE

cd_or_fail "$WORKING_DIR" help_and_exit

if [[ "$more" == "yes" ]]; then
    echodetailedhelp "$section"
else
    echolistoffunctions
fi

echoend
