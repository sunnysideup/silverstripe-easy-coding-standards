#!/usr/bin/env bash

############################################ ENVIRONMENT SETUP

envFileLocation="$HOME/.config/composer/.env"
DEFAULT_SERVER_DIR='/container/application'
# Create .env file if it doesn't exist
touch "$envFileLocation"

if [ ! -f "$envFileLocation" ]; then
    echobad ".env file not found here: $envFileLocation"
    exit 1
fi

declare -A varsToAdd=(
    [GITHUB_USER_NAME]=''
    [GITHUB_MATCH_URL_FOR_VENDOR_PACKAGES]=''
    [SCRUTINIZER_API_TOKEN]=''
    [SCRUTINIZER_ORG]=''
    [PACKAGIST_USERNAME]=''
    [PACKAGIST_API_TOKEN]=''
    [LLM_PROVIDER]=''
    [LLM_API_KEY]=''
    [LLM_MODEL]=''
)


# Loop through vars and add them if missing
for key in "${!varsToAdd[@]}"; do
    if ! grep -q "^$key=" "$envFileLocation"; then
        echo "$key=${varsToAdd[$key]}" >>"$envFileLocation"
    fi
done

# Load the .env file
source "$envFileLocation"


############################################ COMMON INITIALIZATION FUNCTIONS

# Standard BASICS section - use at the start of each script:
# SCRIPT_DIR="${COMPOSER_RUNTIME_BIN_DIR:?COMPOSER_RUNTIME_BIN_DIR not set}"
# WORKING_DIR="$(pwd)"
# source "$SCRIPT_DIR/sake-self-methods"

# Standard flag handler for argument parsing (Handles Help and Quiet modes)
# Returns 0 (success) if the flag was handled here, 1 if the parent script needs to handle it.
# Usage: In your script's case statement, call: sake_handle_help_flag "$1" && shift && continue
sake_handle_help_flag() {
    case "$1" in
    -h | --help)
        help='yes'
        return 0
        ;;
    -q | --quiet)
        # Magic happens here: Redirect all stderr (logs/UI) to the void for the entire script
        exec 2>/dev/null
        return 0
        ;;
    -*)
        # If it's a flag we don't recognize in the shared library, let the parent script handle it.
        # If the parent script also doesn't recognize it, the parent script should throw the error.
        return 1
        ;;
    esac
    return 1
}

# Check if help was requested and call help_and_exit function
# Usage: sake_check_help_and_exit
sake_check_help_and_exit() {
    if [[ "${help:-no}" == "yes" ]]; then
        help_and_exit
    fi
}

############################################ COLOURS / LOGGING (stderr)
# Notes:
# - Uses printf (predictable) instead of echo -e (inconsistent).
# - All visual output is forced to >&2 so stdout remains pure for data pipelines.
# - Resets colour every time.

_ESC=$'\033'
_COL_RESET="${_ESC}[0m"
_COL_NICE="${_ESC}[0;33m"
_COL_GOOD="${_ESC}[0;32m"
_COL_HEAD="${_ESC}[95m"
_COL_BAD_BG="${_ESC}[1;32;44m"

_print_stderr() {
    printf ' %s\n' "$*" >&2
}

_print_col_stderr() {
    local colour="$1"
    shift
    printf ' %b%s%b\n' "$colour" "$*" "$_COL_RESET" >&2
}

_print_banner() {
    local colour="$1"
    local line='----------------------------------------'
    printf '%b %s %b\n' "$colour" "$line" "$_COL_RESET" >&2
}

echoplain() {
    _print_stderr "$@"
}

echonice() {
    _print_col_stderr "$_COL_NICE" "$@"
}

echogood() {
    _print_col_stderr "$_COL_GOOD" "✅ $*"
}

echobad() {
    _print_banner "$_COL_BAD_BG"
    printf '%b ❌: %s %b\n' "$_COL_BAD_BG" "$*" "$_COL_RESET" >&2
    _print_banner "$_COL_BAD_BG"
}

echowarn() {
    _print_banner "$_COL_BAD_BG"
    printf ' ⚠️ %s\n' "$*" >&2
    _print_banner "$_COL_BAD_BG"
}

echoline() {
    echonice '----------------------------------------'
}

ECHOHEAD() {
    local string="${1-}"

    if [[ -z "$string" ]]; then
        string='#'
    elif [[ "$string" != \#* ]]; then
        string="# $string"
    fi

    printf '\n\n\n' >&2
    echoline
    _print_col_stderr "$_COL_HEAD" "$string"
    echoline
}

echoend() {
    echo "" >&2
    echoline
    echogood "COMPLETED"
    echoline

}

echofunctions() {
    ECHOHEAD 'Available Functions? Run ...'
    echogood "sake-help"
    echoline
}


############################################ HELP



echolistoffunctions() {
    ECHOHEAD 'List of Available Functions'

    local categorized_scripts=()

    for entry in "$SCRIPT_DIR"/*; do
        if [[ -f "$entry" && -x "$entry" ]]; then
            local script
            script="$(basename "$entry")"
            local category label

            if [[ "$script" == sake-*-* ]]; then
                local without_sake="${script#sake-}"
                category="${without_sake%%-*}"
                category="${category^^}"
                # Everything after "sake-category-"
                label="${without_sake#*-}"
            else
                category="GENERAL"
                label="${script#sake-}"
                [[ "$label" == "$script" ]] && label="$script"
            fi

            categorized_scripts+=("$category:$label:$script")
        fi
    done

    if (( ${#categorized_scripts[@]} > 0 )); then
        local sorted_scripts=()
        while IFS= read -r line; do
            sorted_scripts+=("$line")
        done < <(printf "%s\n" "${categorized_scripts[@]}" | sort)

        local current_category=""

        for item in "${sorted_scripts[@]}"; do
            local category="${item%%:*}"
            local rest="${item#*:}"
            local label="${rest%%:*}"
            local script="${rest#*:}"

            if [[ "$category" != "$current_category" ]]; then
                echo "" >&2
                _print_col_stderr "$_COL_HEAD" "# $category"
                current_category="$category"
            fi

            printf '  - %-24s %s\n' "$label:" "$script" >&2
        done
    fi

    echo "" >&2
    echonice "To show the options for a specific command, run:"
    echo "[command] -h" >&2
    echonice "e.g. sake-lint-all -h"
}

echodetailedhelp() {
    ECHOHEAD 'Detailed Help for All Functions'
    echonice "Compact summaries for all available scripts"
    echo "" >&2

    local categorized_scripts=()

    # Collect all scripts
    for entry in "$SCRIPT_DIR"/*; do
        if [[ -f "$entry" && -x "$entry" ]]; then
            local script
            script="$(basename "$entry")"
            
            # Skip self-methods as it's not a user command
            [[ "$script" == "sake-self-methods" ]] && continue
            [[ "$script" == "ecs" ]] && continue
            
            local category label

            if [[ "$script" == sake-*-* ]]; then
                local without_sake="${script#sake-}"
                category="${without_sake%%-*}"
                category="${category^^}"
                label="${without_sake#*-}"
            else
                category="GENERAL"
                label="${script#sake-}"
                [[ "$label" == "$script" ]] && label="$script"
            fi

            categorized_scripts+=("$category:$label:$script:$entry")
        fi
    done

    if (( ${#categorized_scripts[@]} > 0 )); then
        local sorted_scripts=()
        while IFS= read -r line; do
            sorted_scripts+=("$line")
        done < <(printf "%s\n" "${categorized_scripts[@]}" | sort)

        local current_category=""

        for item in "${sorted_scripts[@]}"; do
            local category="${item%%:*}"
            local rest="${item#*:}"
            local label="${rest%%:*}"
            rest="${rest#*:}"
            local script="${rest%%:*}"
            local path="${rest#*:}"

            # Show category header
            if [[ "$category" != "$current_category" ]]; then
                echo "" >&2
                _print_col_stderr "$_COL_HEAD" "# $category"
                current_category="$category"
            fi

            # Extract compact summary
            if output=$("$path" -h 2>&1); then
                # Remove ANSI color codes for cleaner processing
                local clean_output=$(echo "$output" | sed 's/\x1b\[[0-9;]*m//g')
                
                # Extract title (first # line)
                local title=$(echo "$clean_output" | grep -m 1 "^.*# " | sed 's/.*# //' | sed 's/^[[:space:]]*//')
                
                # Extract summary: lines between first header and next section
                # Skip directory lines, empty lines, and separator lines
                local summary=$(echo "$clean_output" | awk '
                    /^.*# / { if (found_title) next; found_title=1; next }
                    found_title && /^.*# / { exit }
                    found_title && /^[-]+$/ { next }
                    found_title && /Directory of script:/ { next }
                    found_title && /Directory to [a-z]+:/ { next }
                    found_title && /directory of script:/ { next }
                    found_title && /directory to [a-z]+:/ { next }
                    found_title && /^[[:space:]]*$/ { next }
                    found_title && NF > 0 { 
                        gsub(/^[[:space:]]+/, "");
                        if (length($0) > 5 && $0 !~ /^[-]+$/) {
                            print; 
                            if (++count >= 1) exit 
                        }
                    }
                ' | head -1 | sed 's/^[[:space:]]*//')
                
                # Show compact summary
                if [[ -n "$summary" && ${#summary} -gt 5 ]]; then
                    printf '  %-35s %s\n' "$script:" "$summary" >&2
                elif [[ -n "$title" ]]; then
                    printf '  %-35s %s\n' "$script:" "$title" >&2
                else
                    printf '  %-35s %s\n' "$script:" "(No summary - run $script -h for details)" >&2
                fi
            else
                printf '  %-35s %s\n' "$script:" "(No help available)" >&2
            fi
        done
    fi

    echo "" >&2
}

############################################ UTILITY FUNCTIONS

addtoscrutinizer() {
    packageWithSilverstripe=$1
    if [ -z "$SCRUTINIZER_API_TOKEN" ]; then
        echobad "Scrutinizer credentials (SCRUTINIZER_API_TOKEN) not set in $envFileLocation file."
        exit 1
    fi
    if [ -z "$packageWithSilverstripe" ]; then
        echobad "Package to be added (packageWithSilverstripe) not provided."
        exit 1
    fi

    scrutinizerApiPath="https://scrutinizer-ci.com/api"
    endPoint="repositories/g?access_token=${SCRUTINIZER_API_TOKEN}"
    url="${scrutinizerApiPath}/${endPoint}"

    postFields="{\"name\": \"${packageWithSilverstripe}\"}"

    curlResult=$(curl -L -s -o /dev/null -w "%{http_code}" -X POST -d "$postFields" -H "Content-Type: application/json" "$url")

    if [ "$curlResult" != "200" ] && [ "$curlResult" != "201" ]; then
        echobad "Could not add ${packageWithSilverstripe} to Scrutinizer (HTTP code: $curlResult)"
        curlResultDetail=$(curl -L -s -X POST -d "$postFields" -H "Content-Type: application/json" "$url")
        echobad "$curlResultDetail"
        return 1
    else
        echonice "${packageWithSilverstripe} added to Scrutinizer successfully."
    fi
}

cd_or_fail() {
    local workingDir="$1"
    local onFailFn="${2:-}"

    if [[ -d "$workingDir" ]]; then
        cd "$workingDir" || return 1
        return 0
    fi

    echobad "Could not change directory to $workingDir"

    if [[ -n "$onFailFn" ]] && declare -F "$onFailFn" >/dev/null 2>&1; then
        "$onFailFn"
        return 1
    fi

    return 1
}

# Extracts a value and outputs to stdout
read_local_dotenv_value() {
    local key="$1"
    local envFile="$WORKING_DIR/.env"

    [[ -f "$envFile" ]] || return 1

    local value=''
    value="$(
        grep -E "^[[:space:]]*(export[[:space:]]+)?${key}=" "$envFile" \
            | tail -n 1 \
            | sed -E "s/^[[:space:]]*(export[[:space:]]+)?${key}=//"
    )"

    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    value="${value%\"}"; value="${value#\"}"
    value="${value%\'}"; value="${value#\'}"

    [[ -n "$value" ]] || return 1

    # Pure data output
    printf '%s' "$value"
}

# Formats a server string and outputs to stdout
normalize_server() {
    local raw="$1"
    [[ "$raw" != *":/"* ]] && raw="$raw:$DEFAULT_SERVER_DIR"

    # Pure data output
    echo "$raw"
}

installpackage() {
    package=$1
    if ! command -v "$package" &>/dev/null; then
        echobad "$package is not installed. Installing now..."
        sudo apt-get update && sudo apt-get install -y "$package"
        sudo snap install "$package"
    else
        echonice "$package is installed."
    fi
}

check_gh_auth() {
    if ! gh auth status &>/dev/null; then
        echobad "You are not logged in to GitHub CLI."
        echonice "Attempting to log in..."
        gh auth login
    else
        echonice "You are already logged in to GitHub CLI."
    fi
}

check_for_env_var() {
    local envVarName="${1:-}"
    if [[ -z "$envVarName" ]]; then
        echobad "check_for_env_var: missing env var name"
        return 1
    fi

    local value="${!envVarName-}"
    if [[ -z "$value" ]]; then
        echobad "Missing required env var: $envVarName"
        return 1
    fi
}

# Outputs an array of matching directories to stdout
get_my_repos() {
    check_for_env_var "GITHUB_MATCH_URL_FOR_VENDOR_PACKAGES" || return 1
    local WORKING_DIR=$1

    declare -a packageDirs
    declare -a found_dirs

    # Step 1: Check composer.lock
    local composerLock="$WORKING_DIR/composer.lock"
    local vendorDir="$WORKING_DIR/vendor"

    if [[ -f "$composerLock" ]]; then
        local packages
        packages=$(jq -r '.packages[]? | "\(.name) \(.source.url)"' "$composerLock" 2>/dev/null)

        while read -r packageName packageUrl; do
            if [[ -n "$packageName" ]]; then
                local packageDir="$vendorDir/$packageName"
                if [ -d "$packageDir/.git" ]; then
                    local remoteUrl
                    remoteUrl=$(git -C "$packageDir" config --get remote.origin.url 2>/dev/null)
                    if [[ "$remoteUrl" == *"$GITHUB_MATCH_URL_FOR_VENDOR_PACKAGES"* ]]; then
                        packageDirs+=("$packageDir")
                        found_dirs+=("$packageDir")
                    fi
                fi
            fi
        done <<<"$packages"
    fi

    # Step 2: Find all git repositories and check config
    while IFS= read -r gitDir; do
        local repoDir
        repoDir=$(dirname "$gitDir")

        local already_found=0
        for dir in "${found_dirs[@]}"; do
            if [[ "$dir" == "$repoDir" ]]; then
                already_found=1
                break
            fi
        done

        if [[ $already_found -eq 0 ]]; then
            if grep -q "$GITHUB_MATCH_URL_FOR_VENDOR_PACKAGES" "$gitDir/config" 2>/dev/null; then
                packageDirs+=("$repoDir")
                found_dirs+=("$repoDir")
            fi
        fi
    done < <(find "$WORKING_DIR" -path "*/\.*" -prune -o -name ".git" -type d -print 2>/dev/null)

    # Pure data output
    for dir in "${packageDirs[@]}"; do
        echo "$dir"
    done
}

# Outputs escaped string to stdout
escape_for_single_quotes() {
    printf "%s" "$1" | sed "s/'/'\\\\''/g"
}

# Validates and outputs commit message to stdout
check_commit_message() {
    local message=$1

    if [[ -z "$message" ]]; then
        # Read from stderr prompt to avoid corrupting stdout
        read -r -p "Commit message: " message < /dev/tty
    fi

    local PREFIXES=("API" "NEW" "ENH" "FIX" "DOC" "DEP" "TLN" "MNT" "Merge")

    if [[ -z "$message" ]]; then
        echobad "Please provide a commit message."
        echonice "Allowed prefixes are: ${PREFIXES[*]}"
        return 1
    fi

    local firstLine
    firstLine=$(echo "$message" | head -n 1)

    for prefix in "${PREFIXES[@]}"; do
        if [[ "$firstLine" == "$prefix"* ]]; then
            # Pure data output
            echo "$message"
            return 0
        fi
    done

    echobad "Commit message ($message) does not start with an allowed prefix."
    echonice "Allowed prefixes are: ${PREFIXES[*]}"
    return 1
}

# Outputs masked key to stdout
mask_api_key() {
    local key="${1-}"
    local keepStart=4
    local keepEnd=4

    if [[ -z "$key" ]]; then
        printf '%s' '(not set)'
        return 0
    fi

    local len=${#key}
    if (( len <= keepStart + keepEnd )); then
        printf '%s' '***'
        return 0
    fi

    # Pure data output
    printf '%s***%s' "${key:0:keepStart}" "${key:len-keepEnd:keepEnd}"
}





############################################ SILVERSTRIPE VERSION DETECTION

declare -A SAKE_CORE_PACKAGES_SS4=(
    ["silverstripe/framework"]="^4"
    ["silverstripe/recipe-cms"]="^4"
    ["silverstripe/recipe-core"]="^4"
    ["silverstripe/cms"]="^4"
    ["silverstripe/admin"]="^1"
    ["dnadesign/silverstripe-elemental"]="^4"
)
declare -A SAKE_CORE_PACKAGES_SS5=(
    ["silverstripe/framework"]="^5"
    ["silverstripe/recipe-cms"]="^5"
    ["silverstripe/recipe-core"]="^5"
    ["silverstripe/cms"]="^5"
    ["silverstripe/admin"]="^2"
    ["dnadesign/silverstripe-elemental"]="^5"
)
declare -A SAKE_CORE_PACKAGES_SS6=(
    ["silverstripe/framework"]="^6"
    ["silverstripe/recipe-cms"]="^6"
    ["silverstripe/recipe-core"]="^6"
    ["silverstripe/cms"]="^6"
    ["silverstripe/admin"]="^3"
    ["dnadesign/silverstripe-elemental"]="^6"
)
declare -A SAKE_CORE_PACKAGES_SS7=(
    ["silverstripe/framework"]="^7"
    ["silverstripe/recipe-cms"]="^7"
    ["silverstripe/recipe-core"]="^7"
    ["silverstripe/cms"]="^7"
    ["silverstripe/admin"]="^4"
    ["dnadesign/silverstripe-elemental"]="^7"
)

# Helper: Safely parses complex composer constraints
# Supports: "^5", "~5.0", "^4 || ^5", "5.x-dev", "^5.0.2", "v5.0", ">=^5"
sake_check_major_version_match() {
    local req_string="$1"
    local expected_major="$2"

    # Replace '||' with a single pipe, then strip all whitespace
    local clean_string="${req_string//||/|}"
    clean_string="${clean_string// /}"

    IFS='|' read -ra parts <<< "$clean_string"
    for part in "${parts[@]}"; do
        # Extract the first sequence of digits (ignores all prefixes like ^, ~, >=, v)
        if [[ "$part" =~ ([0-9]+) ]]; then
            local major="${BASH_REMATCH[1]}"
            if [[ "$major" == "$expected_major" ]]; then
                return 0
            fi
        fi
    done
    return 1
}

# Extracts the SS version from composer.json.
# Returns: 4, 5, 6, 7, "none", or "inconsistent: X Y"
sake_determine_ss_version() {
    local json="$1"
    local found_versions=()

    # Note: Packages with transitional constraints like "^5 || ^6"
    # will match multiple matrices and return e.g. "inconsistent: 6 5".
    # This is correct behavior, as it requires manual review for strict alignment.
    for ver_key in "SS7" "SS6" "SS5" "SS4"; do

        # Defensive guard against injection if this loop is ever made dynamic
        [[ "$ver_key" =~ ^SS[0-9]+$ ]] || continue

        local expected_major="${ver_key#SS}"
        local matrix_name="SAKE_CORE_PACKAGES_$ver_key"
        local keys
        eval "keys=(\"\${!$matrix_name[@]}\")"

        for pkg in "${keys[@]}"; do
            local req
            req=$(echo "$json" | jq -r ".require[\"$pkg\"] // empty" 2>/dev/null)

            if [[ -n "$req" ]]; then
                local expected_constraint
                eval "expected_constraint=\${$matrix_name[$pkg]}"

                # We also need to extract the major version from our expected constraint matrix
                local pkg_expected_major=""
                if [[ "$expected_constraint" =~ ([0-9]+) ]]; then
                    pkg_expected_major="${BASH_REMATCH[1]}"
                fi

                if [[ -n "$pkg_expected_major" ]] && sake_check_major_version_match "$req" "$pkg_expected_major"; then
                    # Check if version is already in our array using a safe loop
                    local already_found=0
                    for v in "${found_versions[@]:-}"; do
                        if [[ "$v" == "$expected_major" ]]; then
                            already_found=1
                            break
                        fi
                    done

                    if [[ $already_found -eq 0 ]]; then
                        found_versions+=("$expected_major")
                    fi
                fi
            fi
        done
    done

    if [[ ${#found_versions[@]} -eq 0 ]]; then
        echo "none"
    elif [[ ${#found_versions[@]} -gt 1 ]]; then
        # Take the highest version (transitional constraints like "^4 || ^5" are fine)
        local highest=0
        for v in "${found_versions[@]}"; do
            (( v > highest )) && highest=$v
        done
        echo "$highest"
    else
        echo "${found_versions[0]}"
    fi
}


######################################## SCAN

# sake-lint-scan-config.sh
# Shared paths/excludes for static analysis tools (PHPStan, Phan, etc.)
# Source this file from any script that needs these values.

# Directories to analyse (only those that exist will be used)
SCAN_CANDIDATE_PATHS=(
    app/src
    app
    src
    themes
)

# Always include these files if they exist
SCAN_EXTRA_FILES=(
    app/_config.php
)

# Directories to exclude
SCAN_EXCLUDE_PATHS=(
    vendor
    node_modules
    .git
    .graphql
    _upgrade
    _dev
    patches
    bin
    public/assets
    datauploadfolder
)

# PHPStan-specific ignore patterns
PHPSTAN_IGNORE_ERRORS=(
    '#Call to an undefined method [a-zA-Z0-9\\_]+::get\(\)#'
    '#Call to an undefined method [a-zA-Z0-9\\_]+::filter\(\)#'
)

# Filter SCAN_CANDIDATE_PATHS to only those that exist in $PWD
scan_get_existing_paths() {
    local result=()
    for p in "${SCAN_CANDIDATE_PATHS[@]}"; do
        [[ -d "$p" ]] && result+=("$p")
    done
    # Deduplicate (e.g. if app/src exists, drop app to avoid scanning twice)
    # Keep the most specific path
    local filtered=()
    for p in "${result[@]}"; do
        local is_parent=0
        for q in "${result[@]}"; do
            if [[ "$p" != "$q" && "$q" == "$p/"* ]]; then
                is_parent=1
                break
            fi
        done
        [[ $is_parent -eq 0 ]] && filtered+=("$p")
    done
    echo "${filtered[@]}"
}

scan_get_existing_extra_files() {
    local result=()
    for f in "${SCAN_EXTRA_FILES[@]}"; do
        [[ -f "$f" ]] && result+=("$f")
    done
    echo "${result[@]}"
}

# Generate a phpstan.neon from the shared config
scan_generate_phpstan_neon() {
    local paths
    read -ra paths <<< "$(scan_get_existing_paths)"
    local extra_files
    read -ra extra_files <<< "$(scan_get_existing_extra_files)"

    if [[ ${#paths[@]} -eq 0 ]]; then
        echobad "No scan paths found in project — cannot generate phpstan.neon"
        return 1
    fi

    {
        echo "parameters:"
        echo "    level: ${1:-1}"
        echo "    paths:"
        for p in "${paths[@]}"; do
            echo "        - $p"
        done
        for f in "${extra_files[@]}"; do
            echo "        - $f"
        done
        echo "    excludePaths:"
        for e in "${SCAN_EXCLUDE_PATHS[@]}"; do
            echo "        - $e (?)"
        done
        echo '        - "*.js"'
        echo "    ignoreErrors:"
        for err in "${PHPSTAN_IGNORE_ERRORS[@]}"; do
            echo "        - '$err'"
        done
        echo "    reportUnmatchedIgnoredErrors: false"
    } > phpstan.neon

    echogood "Generated phpstan.neon with paths: ${paths[*]}"
}

# Build Phan CLI args from the shared config
scan_get_phan_directory_args() {
    local paths
    read -ra paths <<< "$(scan_get_existing_paths)"
    local extra_files
    read -ra extra_files <<< "$(scan_get_existing_extra_files)"

    local args=()
    for p in "${paths[@]}"; do
        args+=(--directory "$p")
    done
    # Phan uses --include-analysis-file-list for individual files
    if [[ ${#extra_files[@]} -gt 0 ]]; then
        local joined
        joined=$(IFS=,; echo "${extra_files[*]}")
        args+=(--include-analysis-file-list "$joined")
    fi
    echo "${args[@]}"
}
