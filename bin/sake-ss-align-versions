#!/usr/bin/env bash

# Exit on undefined variables and pipe failures
set -euo pipefail

############################################ BASICS
SCRIPT_DIR="${COMPOSER_RUNTIME_BIN_DIR:?COMPOSER_RUNTIME_BIN_DIR not set}"
WORKING_DIR="$(pwd)"
source "$SCRIPT_DIR/sake-self-methods"

############################################ SETTINGS
dry_run="no"
fail_on_drift="no"
single_repo=""

while (($#)); do
    case $1 in
    -d | --dry-run)
        dry_run="yes"
        ;;
    -f | --fail-on-drift)
        fail_on_drift="yes"
        ;;
    -r | --repo)
        shift
        if [[ $# -eq 0 || -z "${1:-}" ]]; then
            echobad "--repo requires a repository name (e.g. --repo silverstripe-blog)"
            exit 1
        fi
        single_repo="$1"
        ;;

    *)
        if sake_handle_help_flag "$1"; then
            shift
            continue
        fi
        ;;
    esac
    shift
done

help_and_exit() {
    ECHOHEAD "sake-ss-align-versions"
    echonice "Aligns Silverstripe version branches across all repositories in a GitHub organization."
    echonice ""
    echonice "Directory of script:           $SCRIPT_DIR"
    echonice "Working directory:             $WORKING_DIR"

    ECHOHEAD "What this script does:"
    echonice "For every repository in the \$GITHUB_USER_NAME organization, this script:"
    echonice ""
    echonice "  1. READS composer.json from the repo and detects whether it targets"
    echonice "     Silverstripe 4, 5, 6, or 7. Skips the repo if:"
    echonice "       - composer.json is missing"
    echonice "       - the module is not classified as SS4/SS5/SS6/SS7"
    echonice "       - dependencies are inconsistent across Silverstripe versions"
    echonice ""
    echonice "  2. CLONES the repo to a temporary directory and inspects every pair"
    echonice "     of numeric version branches (4, 5, 6, 7) in the pristine remote"
    echonice "     state to detect lower branches that are ahead of higher branches."
    echonice "     Results are collected and printed at the end of the script."
    echonice ""
    echonice "  3. CHECKS OUT the default branch and a target branch named after the"
    echonice "     detected version (e.g. '5' for Silverstripe 5). Creates the target"
    echonice "     branch if missing."
    echonice ""
    echonice "  4. PINS \$GITHUB_ORG/* dependencies per branch:"
    echonice "       - default branch (main/master) → 'dev-main'"
    echonice "       - numeric version branches      → 'N.x-dev' (e.g. 6.x-dev)"
    echonice "     Commits the change on each branch if anything was modified."
    echonice ""
    echonice "  5. MERGES the default branch (main) into the TARGET version branch —"
    echonice "     i.e. the branch matching the SS version detected from main's"
    echonice "     composer.json (e.g. main → branch '6' for an SS6 module)."
    echonice "     NOT the highest numeric branch present on the remote: that would"
    echonice "     drag newer code backwards into older-version branches when the"
    echonice "     target branch hasn't been created on the remote yet."
    echonice "     Uses a 'merge + re-pin' strategy:"
    echonice "       - perform the merge normally"
    echonice "       - if composer.json conflicts, take the incoming version"
    echonice "       - re-pin \$GITHUB_ORG/* deps to the target branch's"
    echonice "         constraint (N.x-dev)"
    echonice "     This ensures main remains the only source of truth and prevents backward contamination."
    echonice "     Any non-composer.json conflict aborts the merge and skips the repo."
    echonice "     These conflicts are listed at the end of script for manual resolution."
    echonice ""
    echonice "  6. MIGRATES 'master' to 'main' if the default branch is still 'master':"
    echonice "       - pushes the merged state to a new 'main' branch"
    echonice "       - sets 'main' as the default branch via the GitHub API"
    echonice "       - deletes the remote 'master' branch once 'main' is confirmed default"
    echonice ""
    echonice "  7. PUSHES the default branch, the target version branch, and any other"
    echonice "     version branches whose composer.json was updated."
    echonice ""
    echonice "  8. AT THE END, reports any lower numeric version branch that has"
    echonice "     commits not present in a higher numeric version branch, based on"
    echonice "     the remote state at clone time. Informational only — the script"
    echonice "     does not forward-port these commits."

    ECHOHEAD "Available settings:"
    echonice "-d, --dry-run                  run through all steps locally without pushing"
    echonice "                               anything to GitHub (no merges pushed, no branch"
    echonice "                               migrations, no default-branch changes)"
    echonice "-r, --repo NAME                process only the single repository NAME inside"
    echonice "                               \$GITHUB_USER_NAME, instead of iterating the whole"
    echonice "                               organization. NAME is the bare repo name (no owner"
    echonice "                               prefix). Useful for testing this script against one"
    echonice "                               module before running it org-wide."
    echonice "-h, --help                     show this help information"
    echonice "-q, --quiet                    suppress visual output"
    echonice "-f, --fail-on-drift            fail if any lower numeric version branch has commits not present in a higher numeric version branch"

    ECHOHEAD "Example usage:"
    echonice "sake-ss-align-versions --dry-run"
    echonice "... clone and attempt all changes locally, report what would happen,"
    echonice "    but push nothing to GitHub"
    echonice ""
    echonice "sake-ss-align-versions --repo silverstripe-blog --dry-run"
    echonice "... run against just the silverstripe-blog repo, no pushes"
    echonice ""
    echonice "sake-ss-align-versions --repo silverstripe-blog"
    echonice "... run for real against just the silverstripe-blog repo"
    echonice ""
    echonice "sake-ss-align-versions"
    echonice "... run for real: push merges, align dependencies, migrate master→main"

    ECHOHEAD "Requirements:"
    echonice "gh                             GitHub CLI, authenticated (gh auth login)"
    echonice "jq                             for editing composer.json"
    echonice "git                            with SSH access to the organization's repos"

    ECHOHEAD "Environment Variables Required:"
    echonice "GITHUB_USER_NAME               GitHub organization name to process."
    echonice "                               Define this in ~/.config/composer/.env"

    ECHOHEAD "Warnings:"
    echowarn "- This script pushes directly to default and version branches."
    echowarn "- The master→main migration deletes the remote 'master' branch."
    echowarn "- Always run with --dry-run first on a new organization."

    echofunctions
    exit 1
}

sake_check_help_and_exit

check_for_env_var "GITHUB_USER_NAME" || exit 1
GITHUB_ORG="$GITHUB_USER_NAME"

############################################ UTILITY FUNCTIONS

# Returns the constraint to pin $GITHUB_ORG/* deps to, based on branch name.
#   numeric branches (4, 5, 6, 7) → "N.x-dev"
#   anything else (main, master)  → "dev-main"
get_branch_constraint() {
    local branch="$1"
    if [[ "$branch" =~ ^[0-9]+$ ]]; then
        echo "$branch.x-dev"
    else
        echo "dev-main"
    fi
}

# Rewrites any $GITHUB_ORG/* packages in require and require-dev to the given constraint.
update_org_deps() {
    local file="composer.json"
    local constraint="$1"

    if [[ ! -f "$file" ]]; then
        return 0
    fi

    jq --arg constraint "$constraint" --arg org "$GITHUB_ORG/" '
        (if has("require") then .require |= with_entries(if .key | startswith($org) then .value = $constraint else . end) else . end) |
        (if has("require-dev") then ."require-dev" |= with_entries(if .key | startswith($org) then .value = $constraint else . end) else . end)
    ' "$file" > "$file.tmp" && mv "$file.tmp" "$file"
}

############################################ MAIN SCRIPT

echowarn "BUILD-MARKER: TUI-2026-04-29 (cwd-safe build; no git-reset on user CWD)"

if [[ "$dry_run" == "yes" ]]; then
    echowarn "RUNNING IN DRY-RUN MODE. NO PUSHES WILL BE MADE."
else
    echowarn "Running in real mode. Changes will be pushed to GitHub. Add --dry-run to test without pushing."
fi

if [[ -n "$single_repo" ]]; then
    echonice "Single-repo mode: only processing $GITHUB_ORG/$single_repo"
fi

if ! gh auth status &>/dev/null; then
    echobad "You are not logged in to GitHub CLI. Please run: gh auth login"
    exit 1
fi

# If single-repo mode, verify the repo exists before doing any work.
if [[ -n "$single_repo" ]]; then
    if ! gh api "repos/$GITHUB_ORG/$single_repo" &>/dev/null; then
        echobad "Repository $GITHUB_ORG/$single_repo not found (or not accessible with current gh auth)."
        exit 1
    fi
fi

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

successful_syncs=0
ahead_report=()      # lines describing lower branches ahead of higher branches
conflict_report=()   # repos skipped due to non-composer.json merge conflicts

if [[ -n "$single_repo" ]]; then
    ECHOHEAD "Processing single repo: $GITHUB_ORG/$single_repo"
else
    ECHOHEAD "Fetching repositories for $GITHUB_ORG..."
fi
# NOTE: do NOT run `git reset --hard` / `git clean -fd` here. At this point
# we have not cd'd anywhere, so those commands would execute in the user's
# current working directory and silently destroy uncommitted work if the
# user happens to be standing in any git repository. The equivalent cleanup
# inside the per-repo loop (after `cd "$repo_dir"`) is safe and sufficient.
while read -r repo; do
    [[ -z "$repo" ]] && continue

    org_repo="$GITHUB_ORG/$repo"
    echoline
    echonice "Analyzing: $org_repo"

    composer_json=$(gh api "repos/$org_repo/contents/composer.json" -H "Accept: application/vnd.github.v3.raw" 2>/dev/null || true)

    if [[ -z "$composer_json" ]]; then
        echowarn "Skipping: No composer.json found."
        continue
    fi

    version=$(sake_determine_ss_version "$composer_json")

    if [[ "$version" == "none" ]]; then
        echonice "Skipping: Not classified as SS4, SS5, SS6, or SS7."
        continue
    fi

    if [[ "$version" == inconsistent* ]]; then
        echobad "Skipping: Module has inconsistent dependencies ($version)"
        continue
    fi

    echogood "Detected compatibility: Silverstripe $version"

    # ----------------------------------------------------
    # REPOSITORY CLONE
    # ----------------------------------------------------
    repo_dir="$TMP_DIR/$repo"

    echonice "Cloning $org_repo..."
    git clone git@github.com:"$org_repo".git "$repo_dir" -q || { echobad "Failed to clone $org_repo"; cd "$TMP_DIR"; continue; }
    cd "$repo_dir" || { echobad "Failed to cd into $repo_dir"; continue; }

    git fetch origin --prune -q

    git reset --hard >/dev/null 2>&1 || true
    git clean -fd >/dev/null 2>&1 || true

    # ----------------------------------------------------
    # AHEAD-CHECK (pristine remote state, before any modifications)
    # ----------------------------------------------------
    # For every pair of numeric version branches, check whether the lower-numbered
    # branch has commits not in the higher-numbered branch. Record findings for the
    # end-of-script report. No fetch needed — `git clone` already populated all
    # refs/remotes/origin/* refs.
    for lower in 4 5 6; do
        for higher in 5 6 7; do
            (( higher <= lower )) && continue
            if git show-ref --verify --quiet "refs/remotes/origin/$lower" \
               && git show-ref --verify --quiet "refs/remotes/origin/$higher"; then
                commits_ahead=$(git log "origin/$higher..origin/$lower" --oneline 2>/dev/null | wc -l | tr -d ' ')
                if (( commits_ahead > 0 )); then
                    ahead_report+=("$org_repo: branch $lower has $commits_ahead commit(s) not in branch $higher")
                fi
            fi
        done
    done

    # ----------------------------------------------------
    # BRANCH SETUP
    # ----------------------------------------------------
    default_branch=$(gh repo view "$org_repo" --json defaultBranchRef -q '.defaultBranchRef.name')
    original_default_branch="$default_branch"
    target_branch="$version"

    # 1. Prepare Default Branch
    git checkout "$default_branch" -q
    git pull origin "$default_branch" -q

    # 2. Prepare Target Branch
    if git ls-remote --heads origin "$target_branch" | grep -q "refs/heads/$target_branch"; then
        echonice "Branch '$target_branch' exists. Fetching..."
        git fetch origin "$target_branch" -q
        git checkout "$target_branch" -q
        git pull origin "$target_branch" -q
    else
        echonice "Branch '$target_branch' does not exist. Creating..."
        git checkout -b "$target_branch" -q

        # Pin deps immediately on newly-created numeric branches
        if [[ "$target_branch" =~ ^[0-9]+$ ]]; then
            constraint="$target_branch.x-dev"
            update_org_deps "$constraint"
            if ! git diff --quiet composer.json 2>/dev/null; then
                echonice "Pinning $GITHUB_ORG dependencies to $constraint on new branch $target_branch..."
                git add composer.json
                git commit -m "MNT Pin $GITHUB_ORG dependencies to $constraint" -q
            fi
        fi
    fi

    # ----------------------------------------------------
    # PIN $GITHUB_ORG/* DEPENDENCIES PER BRANCH
    # ----------------------------------------------------
    extra_branches_to_push=()

    # 3a. Default branch — only if it's a non-numeric branch (main/master style).
    #     Numeric defaults are handled by the 4/5/6/7 loop below.
    if ! [[ "$default_branch" =~ ^[0-9]+$ ]]; then
        git checkout "$default_branch" -q
        default_constraint=$(get_branch_constraint "$default_branch")
        update_org_deps "$default_constraint"
        if ! git diff --quiet composer.json 2>/dev/null; then
            echonice "Pinning $GITHUB_ORG dependencies to $default_constraint on $default_branch..."
            git add composer.json
            git commit -m "MNT Pin $GITHUB_ORG dependencies to $default_constraint" -q
        fi
    fi

    # 3b. Numeric version branches (4, 5, 6, 7)
    for check_branch in 4 5 6 7; do

        if git show-ref --verify --quiet "refs/remotes/origin/$check_branch"; then

            git checkout "$check_branch" -q

            constraint="$check_branch.x-dev"
            update_org_deps "$constraint"

            if ! git diff --quiet composer.json 2>/dev/null; then
                echonice "Pinning $GITHUB_ORG dependencies to $constraint on branch $check_branch..."
                git add composer.json
                git commit -m "MNT Align $GITHUB_ORG dependencies with SS$check_branch" -q
            fi

            if [[ "$check_branch" != "$target_branch" && "$check_branch" != "$default_branch" ]]; then
                extra_branches_to_push+=("$check_branch")
            fi
        fi

    done

    # ----------------------------------------------------
    # ONE-WAY MERGE (default_branch → target_branch)
    # ----------------------------------------------------
    # The target branch is the SS version detected from the default branch's
    # composer.json. By definition, that branch is the one that should mirror
    # the default branch's content. Merging into any *other* numeric branch
    # (e.g. the highest existing one on the remote) risks pushing newer-version
    # code backwards into older-version branches — for example, on an SS6
    # module where branch '6' doesn't exist remotely yet and only '5' does,
    # the merge target must be '6' (newly created from main), NOT '5'.

    if [[ "$default_branch" != "$target_branch" ]]; then
        echonice "Merging $default_branch → $target_branch (target version branch)"
        git checkout "$target_branch" -q

        if ! git merge --no-edit "$default_branch" -q; then
            conflicts=$(git diff --name-only --diff-filter=U | grep -v '^composer.json$' || true)
            if [[ -n "$conflicts" ]]; then
                git merge --abort
                echobad "Conflict in $target_branch (non-composer.json). Skipping."
                conflict_report+=("$org_repo: non-composer.json conflict merging $default_branch → $target_branch ($(echo "$conflicts" | tr '\n' ' '))")
                cd "$TMP_DIR"
                continue
            fi
            git checkout --theirs composer.json
            git add composer.json
            git commit --no-edit -q
        fi

        # Re-pin $GITHUB_ORG/* deps to target_branch's own constraint.
        pin_constraint=$(get_branch_constraint "$target_branch")
        update_org_deps "$pin_constraint"

        if ! git diff --quiet composer.json; then
            git add composer.json
            git commit -m "MNT Re-pin deps on $target_branch" -q
        fi

        # target_branch is pushed by the main push step below — no need to
        # add it to extra_branches_to_push.
    fi

    # ----------------------------------------------------
    # PUSH UPDATES AND HANDLE MASTER -> MAIN MIGRATION
    # ----------------------------------------------------
    if [[ "$dry_run" == "yes" ]]; then
        echogood "DRY RUN: Success. Skipping pushes for $org_repo."
    else
        echonice "Merges successful. Preparing to push..."

        # Master -> Main migration happens BEFORE we push the default branch,
        # to avoid pushing merges into remote 'master'.
        if [[ "$original_default_branch" == "master" ]]; then
            echonice "Migrating 'master' to 'main'..."
            git checkout master -q
            git checkout -b main -q

            git push -u origin main -q
            gh repo edit "$org_repo" --default-branch main

            new_default=$(gh repo view "$org_repo" --json defaultBranchRef -q '.defaultBranchRef.name')
            if [[ "$new_default" == "main" ]]; then
                if ! git push origin --delete master -q 2>/dev/null; then
                    echowarn "NOTICE: 'main' is default, but failed to delete remote 'master'. You may need to clean it up manually."
                fi
                git branch -d master -q || true
                echogood "Migrated master → main."
            else
                echobad "Failed to confirm 'main' is default via API. Did not delete master."
            fi

            default_branch="main"
        else
            git push origin "$default_branch" -q
        fi

        if [[ "$default_branch" != "$target_branch" ]]; then
            git push origin "$target_branch" -q
        fi

        # Duplicate Push Prevention
        if (( ${#extra_branches_to_push[@]} > 0 )); then
            # Use tr and sort -u to unique the list in case a branch was
            # added in both the pinning loop and the merge block
            unique_branches=$(echo "${extra_branches_to_push[@]}" | tr ' ' '\n' | sort -u)
            for ex_branch in $unique_branches; do
                git push origin "$ex_branch" -q
            done
        fi

        echogood "Successfully synced $org_repo"
        successful_syncs=$((successful_syncs + 1))
    fi

    cd "$TMP_DIR"

done < <(
    if [[ -n "$single_repo" ]]; then
        echo "$single_repo"
    else
        gh repo list "$GITHUB_ORG" --limit 1000 --json name --jq '.[].name'
    fi
)

ECHOHEAD "All Repositories Processed."
if [[ "$dry_run" == "no" ]]; then
    echogood "Successfully synchronized $successful_syncs repositories."
fi

# ----------------------------------------------------
# AHEAD-BRANCH REPORT (end-of-script)
# ----------------------------------------------------
if (( ${#ahead_report[@]} > 0 )); then
    ECHOHEAD "Lower branches ahead of higher branches:"
    echonice "The following repos have a lower numeric version branch with commits"
    echonice "that are not present in a higher numeric version branch. This may"
    echonice "indicate unported fixes that should be forward-merged manually."
    echonice "(Based on remote state at clone time.)"
    echonice ""
    for entry in "${ahead_report[@]}"; do
        echowarn "$entry"
    done
    if (( ${#ahead_report[@]} > 0 )) && [[ "$fail_on_drift" == "yes" ]]; then
        echobad "Drift detected — failing as requested"
        exit 1
    fi
else
    echogood "No lower-version branches are ahead of higher-version branches."
fi

# ----------------------------------------------------
# CONFLICT REPORT (end-of-script)
# ----------------------------------------------------
if (( ${#conflict_report[@]} > 0 )); then
    ECHOHEAD "Repositories skipped due to merge conflicts:"
    echonice "The following repos had non-composer.json conflicts when merging"
    echonice "the default branch into the highest numeric branch. These require"
    echonice "manual resolution."
    echonice ""
    for entry in "${conflict_report[@]}"; do
        echobad "$entry"
    done
fi

echoend
