#!/usr/bin/env bash

############################################ BASICS
SCRIPT_DIR="${COMPOSER_RUNTIME_BIN_DIR:?COMPOSER_RUNTIME_BIN_DIR not set}"
WORKING_DIR=$(pwd)
source "$SCRIPT_DIR/sake-self-methods"
SCRIPT_SUMMARY="Runs complete security update workflow with tests and composer updates"

############################################ DIR
dir='./'

############################################ STEPS
# Each entry: "Label ::: command"
# Add / remove / reorder steps here -- everything else adapts.
# Internal field separator: ASCII Unit Separator (0x1F).
# Safe because it never appears in labels, commands, or comments.
readonly FS=$'\x1f'

STEPS=()

# add_step <label> <command> [comment]
add_step() {
    STEPS+=("${1}${FS}${2}${FS}${3-}")
}

## CLEAN PROJECT:
add_step \
    'Checkout develop branch' \
    'git checkout develop' \
    ''
add_step \
    'Show git status' \
    'git status' \
    ''
add_step \
    'Quick commit (cleanup)' \
    'sake-git-commit-quick -m "FIX: cleanup"' \
    ''
add_step \
    'Check vendor packages' \
    'sake-git-commit-and-push-vendor-packages . -s "yes"' \
    ''

## REVERSE MERGE:
add_step \
    'Merge production into develop' \
    'sake-git-merge-towards-production -r' \
    ''
add_step \
    'Rsync all - ' \
    'sake-ss-rsync-all' \
    'make sure you have set up your preferred server in your .env SS_SERVER_FOR_EXAMPLE_DATA'
add_step \
    'Dev build (pass 1)' \
    'sake-ss-dev-build' \
    ''
add_step \
    'Apply patches (pass 2)' \
    'bin/apply-patches.sh' \
    ''
add_step \
    'Run tests (pass 2)' \
    'bin/tests.sh' \
    ''

## COMPOSER UPDATE:
add_step \
    'Composer update (pass 1)' \
    'sake-composer-update' \
    ''

# LINT AND CHECK:
add_step \
    'Lint app' \
    'sake-lint-all [APP_FOLDERS]' \
    ''
add_step \
    'Lint app' \
    'sake-lint-remove-origs [APP_FOLDERS]' \
    ''
add_step \
    'Check namespaces' \
    'sake-composer-check-namespacing [APP_FOLDERS]' \
    ''
add_step \
    'Dev build (pass 2)' \
    'sake-ss-dev-build' \
    ''
add_step \
    'Apply patches (pass 2)' \
    'bin/apply-patches.sh' \
    ''
add_step \
    'Run tests (pass 2)' \
    'bin/tests.sh' \
    ''
add_step \
    'Run Security Checks' \
    'sake-lint-security --all' \
    ''
add_step \
    'Write all Data Objects!' \
    'vendor/bin/sake dev/tasks/write-all-data-objects' \
    ''
add_step \
    'Check all end-points' \
    'sake dev/tasks/smoketestcli' \
    'This does not work in SS5, and you will need to run this manually.'

## COMMIT AND PUSH TOWARDS PRODUCTION:
add_step \
    'Commit and push!' \
    'sake-git-commit-and-push -m "FIX: update security checker"' \
    ''

add_step \
    'Push to production' \
    'sake-git-merge-towards-production --ship' \
    'Make sure you have carried out all your checks and are ready to deploy before running this step!'

TOTAL_STEPS=${#STEPS[@]}

# --- accessors (same call convention as before: step_label 0, etc.) ---

step_label() {
    local e="${STEPS[$1]}"
    printf '%s' "${e%%"$FS"*}"
}

step_cmd() {
    local e="${STEPS[$1]}"
    e="${e#*"$FS"}"            # drop label
    printf '%s' "${e%%"$FS"*}" # keep up to next FS
}

step_comment() {
    local e="${STEPS[$1]}"
    printf '%s' "${e##*"$FS"}"
}
############################################ SETTINGS
force="no"
list_only="no"
from_step=1
to_step=$TOTAL_STEPS

while (($#)); do
    case $1 in
    -f | --force)
        force="yes"
        ;;
    -l | --list)
        list_only="yes"
        ;;
    --from)
        from_step=$2
        shift
        ;;
    --to)
        to_step=$2
        shift
        ;;
    *)
        if sake_handle_help_flag "$1"; then
            shift
            continue
        fi
        dir=$1
        ;;
    esac
    shift
done

############################################ APP FOLDERS
# Level-1 folders under $dir that:
#   - are not _dev, vendor, bin, or themes
#   - do not contain a _manifest_exclude file
APP_FOLDERS=()
discover_app_folders() {
    local base="${1:-.}"
    local d name
    APP_FOLDERS=()
    shopt -s nullglob
    for d in "$base"/*/; do
        d="${d%/}"
        name="${d##*/}"
        case "$name" in
        _dev | vendor | bin | themes) continue ;;
        esac
        [[ -e "$d/_manifest_exclude" ]] && continue
        APP_FOLDERS+=("$name")
    done
    shopt -u nullglob
}

discover_app_folders "$dir"

help_and_exit() {

    ECHOHEAD "Run the SilverStripe security update workflow"
    echonice "$SCRIPT_SUMMARY"
    echonice ""
    echonice "Runs complete security update workflow including composer updates and testing"
    echonice ""
    echonice "Directory of script:          $SCRIPT_DIR"
    echonice "Directory to analyse:         $WORKING_DIR/$dir"
    echonice "Total steps:                  $TOTAL_STEPS"
    echonice "App folders detected:         ${APP_FOLDERS[*]:-(none)}"

    ECHOHEAD "Available settings:"
    echonice "-f, --force                   run all steps without prompts"
    echonice "-l, --list                    list all steps and exit"
    echonice "    --from N                  start from step N (1..$TOTAL_STEPS)"
    echonice "    --to N                    stop after step N"
    echonice "-h, --help                    display this help message and exit"

    ECHOHEAD "Per-step controls:"
    echonice "Before each step you'll be prompted with:"
    echonice "    [O]K           run the step"
    echonice "    [S]kip         skip and move on"
    echonice "    [Q]uit         exit the script"
    echonice "After each step you'll be prompted with:"
    echonice "    [O]K           continue to next step"
    echonice "    [R]un again    run this step again"
    echonice "    [C]ontinue     (only if the step failed) continue anyway"
    echonice "    [Q]uit         exit the script"

    ECHOHEAD "Example usage:"
    echonice "sake-ss-security-update ./"
    echonice "sake-ss-security-update ./ -f"
    echonice "sake-ss-security-update --list"
    echonice "sake-ss-security-update --from 5"
    echonice "sake-ss-security-update --from 3 --to 7"
    exit 1
}

declare -A BRANCH_RESULTS

sake_check_help_and_exit

############################################ LIST STEPS (--list)
if [[ "$list_only" == "yes" ]]; then
    ECHOHEAD "All steps in this workflow:"
    for ((i = 0; i < TOTAL_STEPS; i++)); do
        n=$((i + 1))
        echonice "$(printf '%2d' "$n"). $(step_label "$i")"
        echonice "     \$ $(step_cmd "$i")"
    done
    exit 0
fi

############################################ VALIDATE RANGE
if ! [[ "$from_step" =~ ^[0-9]+$ ]] || ((from_step < 1 || from_step > TOTAL_STEPS)); then
    echo "Invalid --from value: '$from_step' (must be 1..$TOTAL_STEPS)" >&2
    exit 1
fi
if ! [[ "$to_step" =~ ^[0-9]+$ ]] || ((to_step < from_step || to_step > TOTAL_STEPS)); then
    echo "Invalid --to value: '$to_step' (must be $from_step..$TOTAL_STEPS)" >&2
    exit 1
fi

############################################ HELPERS
# prompt_choice "<prompt>" "<default-letter>" "<valid letters separated by |>"
prompt_choice() {
    local prompt="$1"
    local default="$2"
    local valid="$3"
    local reply
    while true; do
        read -rp "$prompt " reply
        reply="${reply,,}"
        [[ -z "$reply" ]] && reply="$default"
        if [[ "|$valid|" == *"|$reply|"* ]]; then
            echo "$reply"
            return
        fi
        echo "Please answer one of: $valid" >&2
    done
}

# Runs a command. If it contains [APP_FOLDERS], runs it once per app folder
# with the placeholder replaced by each folder name. Returns non-zero if any
# invocation failed (keeps the last failing exit code).
run_step_cmd() {
    local cmd="$1"

    if [[ "$cmd" != *'[APP_FOLDERS]'* ]]; then
        eval "$cmd"
        return $?
    fi

    if ((${#APP_FOLDERS[@]} == 0)); then
        echonice "No app folders found for [APP_FOLDERS] -- nothing to run."
        return 0
    fi

    local folder expanded rc=0 this_rc
    for folder in "${APP_FOLDERS[@]}"; do
        expanded="${cmd//\[APP_FOLDERS\]/$folder}"
        echonice "-> $expanded"
        eval "$expanded"
        this_rc=$?
        ((this_rc != 0)) && rc=$this_rc
    done
    return $rc
}

############################################ RUN STEPS
ECHOHEAD "Running steps $from_step..$to_step of $TOTAL_STEPS"

for ((i = from_step - 1; i < to_step; i++)); do
    step_num=$((i + 1))
    label="$(step_label "$i")"
    cmd="$(step_cmd "$i")"
    comment="$(step_comment "$i")"

    while true; do
        ECHOHEAD "Step $step_num/$TOTAL_STEPS: $label"
        echonice "Command: $cmd"
        echonice "Comment: $comment"

        if [[ "$force" == "yes" ]]; then
            action="o"
        else
            action=$(prompt_choice "[O]K / [S]kip / [Q]uit (default O):" "o" "o|s|q")
        fi

        case "$action" in
        s)
            echonice "-> Skipped step $step_num."
            break
            ;;
        q)
            echonice "-> Quit at step $step_num."
            exit 0
            ;;
        o)
            run_step_cmd "$cmd"
            rc=$?
            echo
            if ((rc == 0)); then
                echonice "OK  Step $step_num completed."
            else
                echonice "ERR Step $step_num failed (exit $rc)."
            fi

            if [[ "$force" == "yes" ]]; then
                if ((rc != 0)); then
                    echonice "-> Stopping (force mode + non-zero exit)."
                    exit "$rc"
                fi
                break
            fi

            if ((rc == 0)); then
                after=$(prompt_choice "[O]K continue / [R]un again / [Q]uit (default O):" "o" "o|r|q")
            else
                after=$(prompt_choice "[R]un again / [C]ontinue anyway / [Q]uit (default Q):" "q" "r|c|q")
            fi
            case "$after" in
            r) continue ;;
            q) exit "$rc" ;;
            o | c) break ;;
            esac
            ;;
        esac
    done
done

echoend
