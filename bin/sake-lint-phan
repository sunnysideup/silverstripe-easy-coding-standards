#!/usr/bin/env bash
############################################ BASICS
SCRIPT_DIR="${COMPOSER_RUNTIME_BIN_DIR:?COMPOSER_RUNTIME_BIN_DIR not set}"
WORKING_DIR=$(pwd)
source "$SCRIPT_DIR/sake-self-methods"

############################################ SETTINGS
phanConfig="$SCRIPT_DIR/../sunnysideup/easy-coding-standards/.phan/config.php"
phpVersion="8.0"

while (($#)); do
    case $1 in
        -s|--phan-config)  phanConfig=$2; shift ;;
        -p|--php-version)  phpVersion=$2; shift ;;
        *)
            if sake_handle_help_flag "$1"; then shift; continue; fi
            ;;
    esac
    shift
done

############################################ HELP
help_and_exit() {

    ECHOHEAD "PHP PHAN"
    echonice "Directory to analyse:             $WORKING_DIR"

    ECHOHEAD "Current settings:"
    echonice "phan config file (-s):            $phanConfig"
    echonice "php version (-p):                 $phpVersion"

    ECHOHEAD "Example usage:"
    echonice "sake-lint-phan -s ../.phan/config.php -p 8.2"
    echofunctions
    exit
}
sake_check_help_and_exit

############################################ CODE
cd_or_fail "$WORKING_DIR" help_and_exit

# Build directory args from shared config
read -ra phan_args <<< "$(scan_get_phan_directory_args)"

"$SCRIPT_DIR/phan" \
    --project-root-directory "$WORKING_DIR" \
    "${phan_args[@]}" \
    --minimum-target-php-version "$phpVersion" \
    --config-file "$phanConfig"

echoend
