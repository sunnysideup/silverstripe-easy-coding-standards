#!/usr/bin/env bash

############################################ BASICS
SCRIPT_DIR="${COMPOSER_RUNTIME_BIN_DIR:?COMPOSER_RUNTIME_BIN_DIR not set}"
WORKING_DIR=$(pwd)
source "$SCRIPT_DIR/sake-self-methods"
SCRIPT_SUMMARY="Generates a SilverStripe .env file from YAML configuration data"

############################################ DIR
dir='./'

############################################ SETTINGS
YMLFILECREATE='no'
YMLFILELOCATION='.env.yml'
help='no'
while (($#)); do
    case $1 in
    -c | --createymlfile)
        YMLFILECREATE='yes'
        ;;
    -y | --ymlfilelocation)
        YMLFILELOCATION=$2
        shift
        ;;
    *)
        if ! sake_handle_help_flag "$1"; then
            dir=$1
        fi
        ;;
    esac
    shift
done

help_and_exit() {

    ECHOHEAD "Create a .env file for Silverstripe based on a yml file of data"
    echonice "Generates a SilverStripe .env file from YAML configuration data"
    echonice ""
    echonice "If the yml file does not exist yet, it is created for you to complete."
    echonice "Once the yml file exists, running again builds the .env file from it."
    echonice ""
    echonice "Directory of script:           $SCRIPT_DIR"
    echonice "Directory to use:              $WORKING_DIR/$dir"

    ECHOHEAD "Available settings:"
    echonice "-c, --createymlfile            (re)create the yml file to enter data"
    echonice "                            -> $YMLFILECREATE"
    echonice "-y, --ymlfilelocation          location of the yml file:"
    echonice "                            -> $YMLFILELOCATION"
    echonice "-h, --help                     show help information"

    ECHOHEAD "Example usage:"
    echonice "sake-ss-create-env-file                 # create yml if missing, otherwise build .env"
    echonice "sake-ss-create-env-file -c              # (re)create the yml file to complete data"
    echonice "sake-ss-create-env-file -y myenv.yml    # use a different yml file"

    echofunctions
    exit
}

sake_check_help_and_exit

############################################ CODE

cd_or_fail "$WORKING_DIR" help_and_exit

# Resolve the yml location to an absolute path (the file may not exist yet, so use realpath -m).
case "$YMLFILELOCATION" in
    /*) : ;;
    *) YMLFILELOCATION="$WORKING_DIR/$YMLFILELOCATION" ;;
esac
YMLFILELOCATION=$(realpath -m "$YMLFILELOCATION")
ENVFILELOCATION=$(realpath -m "$WORKING_DIR/.env")

echonice "YML file location: $YMLFILELOCATION"

PHP_CLASS_FILE="${SCRIPT_DIR}/../sunnysideup/env-file-generator/src/EnvFileGenerator.php"

############################################ CREATE YML (when asked, or when it does not exist)

if [[ "$YMLFILECREATE" == "yes" || ! -f "$YMLFILELOCATION" ]]; then

    if [[ ! -f "$YMLFILELOCATION" ]]; then
        echonice "No yml file found - creating one for you to complete."
    else
        echonice "Recreating the yml file."
    fi

    phpCode="require '${PHP_CLASS_FILE}';
\\Sunnysideup\\EnvFileGenerator\\EnvFileGenerator::outputExampleFile('${YMLFILELOCATION}');"

    echo "Running: php -r \"$phpCode\""
    php -r "$phpCode"

    echonice "Created: $YMLFILELOCATION"
    echonice "Please edit it with your values, then run this command again to build the .env file."
    echoend
    exit 0
fi

############################################ BUILD ENV (yml exists)

echonice "Building env file: $ENVFILELOCATION"

phpCode="require '${PHP_CLASS_FILE}';
\\Sunnysideup\\EnvFileGenerator\\EnvFileGenerator::buildEnvFile('${YMLFILELOCATION}', '${ENVFILELOCATION}', '${ENVFILELOCATION}');"

echo "Running: php -r \"$phpCode\""
php -r "$phpCode"

echonice "Built: $ENVFILELOCATION"
echoend
