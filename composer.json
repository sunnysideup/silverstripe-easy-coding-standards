{
  "name": "sunnysideup/easy-coding-standards",
  "type": "silverstripe-vendormodule",
  "description": "ECS PHP Linting.",
  "keywords": [
    "Silverstripe-CMS",
    "CMS",
    "Silverstripe",
    "PHP",
    "Linting",
    "linter",
    "clean",
    "easy coding standards",
    "PHP-CS-Fixer",
    "PHP_CodeSniffer",
    "phpstan"
  ],
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Nicolaas Francken",
      "email": "modules@sunnysideup.co.nz",
      "role": "lead developer"
    }
  ],
  "require": {
    "phan/phan": "*@stable",
    "pheromone/phpcs-security-audit": "*",
    "phpcompatibility/php-compatibility": "dev-develop",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-strict-rules": "*",
    "rector/rector": "^2.3",
    "squizlabs/php_codesniffer": "^4",
    "sunnysideup/env-file-generator": "dev-main",
    "symplify/easy-coding-standard": "^13.0",
    "cambis/silverstan": "*",
    "phpstan/extension-installer": "*",
    "wernerkrauss/silverstripe-rector": "dev-main",
    "friendsofphp/php-cs-fixer": "*"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "bin": [
"bin/sake-composer-about",
"bin/sake-composer-available-updates",
"bin/sake-composer-force-update",
"bin/sake-composer-fork-comparison",
"bin/sake-composer-require",
"bin/sake-composer-update",
"bin/sake-find-in-files",
"bin/sake-find-large-files",
"bin/sake-find-large-folders",
"bin/sake-git-commit-and-push",
"bin/sake-git-commit-and-push-vendor-packages",
"bin/sake-git-commit-quick",
"bin/sake-git-commit-tag",
"bin/sake-git-diff",
"bin/sake-git-diff-analyser",
"bin/sake-git-find-any-changes",
"bin/sake-git-info",
"bin/sake-git-merge-pipeline-ssh",
"bin/sake-git-merge-towards-production",
"bin/sake-git-pm-master-to-main",
"bin/sake-git-pm-my-pull-requests",
"bin/sake-git-pm-my-work-being-forked",
"bin/sake-git-pm-scrutinizer-add",
"bin/sake-git-squash-and-pr",
"bin/sake-git-squash-commits",
"bin/sake-git-squash-stale-branches",
"bin/sake-help",
"bin/sake-lint-all",
"bin/sake-lint-class-rename-comparison",
"bin/sake-lint-compat",
"bin/sake-lint-ecs",
"bin/sake-lint-ide-annotator",
"bin/sake-lint-js",
"bin/sake-lint-one-file",
"bin/sake-lint-phan",
"bin/sake-lint-psr-4-checker",
"bin/sake-lint-rector",
"bin/sake-lint-remove-origs",
"bin/sake-lint-security",
"bin/sake-lint-stan",
"bin/sake-llm-opencode",
"bin/sake-npm-audit",
"bin/sake-npm-build",
"bin/sake-npm-dev",
"bin/sake-npm-install",
"bin/sake-npm-publish-on-npmjs-org",
"bin/sake-npm-update-self",
"bin/sake-npm-watch",
"bin/sake-php-line-counter",
"bin/sake-php-set-timezone",
"bin/sake-self-methods",
"bin/sake-self-update",
"bin/sake-ss-align-versions",
"bin/sake-ss-contribute-step-1",
"bin/sake-ss-contribute-step-2",
"bin/sake-ss-create-env-file",
"bin/sake-ss-db-dump",
"bin/sake-ss-db-import",
"bin/sake-ss-db-open",
"bin/sake-ss-dev-build",
"bin/sake-ss-flush",
"bin/sake-ss-ready",
"bin/sake-ss-rsync-all",
"bin/sake-ss-rsync-assets",
"bin/sake-ss-rsync-db",
"bin/sake-ss-rsync-sspak",
"bin/sake-ss-security-update",
"bin/sake-ss-start-new-feature",
"bin/sake-ss-start-new-module",
"bin/sake-ss-start-new-site",
"bin/sake-ss-start-test-site",
"bin/sake-ss-template-check",
"bin/sake-test-site",
"bin/sake-update-chromium",
"bin/sake-update-composer",
"bin/sake-update-vs-code"

  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": false,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "Sunnysideup\\EasyCodingStandards\\": "src/"
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "git@github.com:sunnysideup/silverstripe-rector.git"
    }
  ]
}
